/* Bilibili 音频下载器 - 样式 */

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --primary-color: #00a1d6;
    --primary-hover: #0087b8;
    --success-color: #52c41a;
    --error-color: #ff4d4f;
    --bg-color: #f5f7fa;
    --card-bg: #ffffff;
    --text-primary: #303133;
    --text-secondary: #606266;
    --border-color: #dcdfe6;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    background-color: var(--bg-color);
    color: var(--text-primary);
    line-height: 1.6;
    min-height: 100vh;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
}

header {
    text-align: center;
    margin-bottom: 40px;
}

header h1 {
    font-size: 2rem;
    color: var(--text-primary);
    margin-bottom: 8px;
}

.subtitle {
    color: var(--text-secondary);
    font-size: 1rem;
}

/* 两栏布局 */
.main-layout {
    display: flex;
    gap: 24px;
}

.left-column {
    flex: 0 0 360px;
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.right-column {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
    min-width: 0;
}

@media (max-width: 900px) {
    .main-layout {
        flex-direction: column;
    }
    .left-column {
        flex: none;
        width: 100%;
    }
}

/* 下载区域 */
.download-section {
    background: var(--card-bg);
    border-radius: 12px;
    padding: 32px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

.input-group {
    display: flex;
    gap: 12px;
}

input[type="text"] {
    flex: 1;
    padding: 12px 16px;
    border: 2px solid var(--border-color);
    border-radius: 8px;
    font-size: 1rem;
    transition: border-color 0.3s;
}

input[type="text"]:focus {
    outline: none;
    border-color: var(--primary-color);
}

input[type="text"]::placeholder {
    color: #909399;
}

button {
    padding: 12px 24px;
    background-color: var(--primary-color);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.3s;
    white-space: nowrap;
}

button:hover {
    background-color: var(--primary-hover);
}

button:disabled {
    background-color: #909399;
    cursor: not-allowed;
}

.btn-loading {
    display: none;
}

/* 进度条 */
.progress-container {
    margin-top: 24px;
    padding: 16px;
    background: #f0f9ff;
    border-radius: 8px;
    border: 1px solid #91d5ff;
}

.progress-info {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
    font-size: 0.9rem;
}

#progressText {
    color: var(--text-secondary);
}

#progressPercent {
    color: var(--primary-color);
    font-weight: 600;
}

.progress-bar {
    height: 8px;
    background: #e8e8e8;
    border-radius: 4px;
    overflow: hidden;
}

.progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--primary-color), #36cfc9);
    border-radius: 4px;
    transition: width 0.3s ease;
    width: 0%;
}

/* 结果显示 */
.result-container {
    margin-top: 24px;
    padding: 16px;
    background: #f6ffed;
    border-radius: 8px;
    border: 1px solid #b7eb8f;
}

.success-message {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--success-color);
    font-weight: 500;
    margin-bottom: 12px;
}

.success-message .icon {
    font-size: 1.2rem;
}

.download-link {
    display: inline-flex;
    align-items: center;
    padding: 8px 16px;
    background: var(--primary-color);
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-size: 0.9rem;
    transition: background-color 0.3s;
}

.download-link:hover {
    background: var(--primary-hover);
}

/* 错误显示 */
.error-container {
    margin-top: 24px;
    padding: 16px;
    background: #fff2f0;
    border-radius: 8px;
    border: 1px solid #ffccc7;
}

.error-message {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--error-color);
    font-weight: 500;
}

.error-message .icon {
    font-size: 1.2rem;
}

/* 播放器区域 */
.player-section {
    background: var(--card-bg);
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

.player-section h2 {
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-color);
}

.player-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
}

.player-cover {
    width: 120px;
    height: 120px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4);
    overflow: hidden;
}

.player-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.player-cover .cover-icon {
    font-size: 48px;
}

.player-cover.playing {
    animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
    0%, 100% {
        transform: scale(1);
    }
    50% {
        transform: scale(1.05);
    }
}

.player-info {
    text-align: center;
}

.player-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    max-width: 300px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.player-artist {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-top: 4px;
}

.player-controls {
    display: flex;
    align-items: center;
    gap: 16px;
}

.player-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #f0f0f0;
    color: var(--text-primary);
    border: none;
    font-size: 1.2rem;
    cursor: pointer;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
}

.player-btn:hover {
    background: #e0e0e0;
    transform: scale(1.1);
}

.player-btn.play-btn {
    width: 56px;
    height: 56px;
    background: var(--primary-color);
    color: white;
    font-size: 1.5rem;
}

.player-btn.play-btn:hover {
    background: var(--primary-hover);
}

.player-progress {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    max-width: 400px;
    font-size: 0.85rem;
    color: var(--text-secondary);
}

.progress-slider {
    flex: 1;
    height: 4px;
    -webkit-appearance: none;
    appearance: none;
    background: #e8e8e8;
    border-radius: 2px;
    cursor: pointer;
}

.progress-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--primary-color);
    cursor: pointer;
}

.player-volume {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
}

.volume-slider {
    width: 80px;
    height: 4px;
    -webkit-appearance: none;
    appearance: none;
    background: #e8e8e8;
    border-radius: 2px;
    cursor: pointer;
}

.volume-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--primary-color);
    cursor: pointer;
}

/* 文件列表 */
.files-section {
    background: var(--card-bg);
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

.files-section h2 {
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-color);
}

.files-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.file-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    background: #fafafa;
    border-radius: 8px;
    transition: background-color 0.2s;
    cursor: pointer;
    gap: 12px;
}

.file-item:hover {
    background: #f0f0f0;
}

.file-item.active {
    background: #e6f7ff;
    border: 1px solid #91d5ff;
}

.file-cover {
    width: 50px;
    height: 50px;
    border-radius: 6px;
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e8e8e8;
}

.file-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.file-info {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
    min-width: 0;
}

.file-icon {
    font-size: 1.5rem;
    color: var(--primary-color);
}

.file-details {
    flex: 1;
    min-width: 0;
}

.file-name {
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.file-size {
    font-size: 0.85rem;
    color: var(--text-secondary);
}

.file-actions {
    display: flex;
    gap: 8px;
}

.file-actions a,
.file-actions button {
    padding: 6px 12px;
    font-size: 0.85rem;
}

.file-actions a {
    background: var(--primary-color);
    color: white;
    text-decoration: none;
    border-radius: 4px;
}

.file-actions button {
    background: var(--error-color);
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
}

.empty-state {
    text-align: center;
    padding: 32px;
    color: var(--text-secondary);
}

/* 页脚 */
footer {
    text-align: center;
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--border-color);
}

footer p {
    color: var(--text-secondary);
    font-size: 0.9rem;
}

footer a {
    color: var(--primary-color);
    text-decoration: none;
}

footer a:hover {
    text-decoration: underline;
}

/* 响应式 */
@media (max-width: 600px) {
    .container {
        padding: 20px 16px;
    }

    .download-section,
    .player-section,
    .files-section {
        padding: 20px;
    }

    .input-group {
        flex-direction: column;
    }

    button {
        width: 100%;
    }

    header h1 {
        font-size: 1.5rem;
    }

    .player-cover {
        width: 100px;
        height: 100px;
    }

    .player-cover .cover-icon {
        font-size: 36px;
    }
}

/* 歌单样式 */
.playlist-section {
    background: #fff;
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    user-select: none;
}

.section-header h2 {
    margin: 0;
}

.toggle-icon {
    font-size: 12px;
    color: var(--text-secondary);
    transition: transform 0.3s;
}

.playlist-header {
    display: flex;
    gap: 10px;
    margin-bottom: 16px;
}

.playlist-header input {
    flex: 1;
    padding: 10px 14px;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    font-size: 14px;
}

.playlist-header button {
    padding: 10px 20px;
    background: var(--primary-color);
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 14px;
}

.playlist-header button:hover {
    background: var(--primary-hover);
}

.playlist-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.playlist-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    background: #f8f9fa;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s;
}

.playlist-item:hover {
    background: #e9ecef;
}

.playlist-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.playlist-name {
    font-weight: 500;
    color: var(--text-primary);
}

.playlist-count {
    font-size: 0.85rem;
    color: var(--text-secondary);
}

.playlist-actions {
    display: flex;
    gap: 8px;
}

.playlist-actions button {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    font-size: 16px;
    opacity: 0.6;
    transition: opacity 0.2s;
}

.playlist-actions button:hover {
    opacity: 1;
}

/* 文件多选样式 */
.file-checkbox {
    width: 18px;
    height: 18px;
    cursor: pointer;
    margin-right: 10px;
}

.files-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
}

.select-all {
    display: flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    font-size: 14px;
    color: var(--text-secondary);
}

.select-all input {
    cursor: pointer;
}

.add-playlist-btn {
    padding: 8px 16px;
    background: var(--primary-color);
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 14px;
}

.add-playlist-btn:hover {
    background: var(--primary-hover);
}

/* 歌单头部行 */
.playlist-header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    cursor: pointer;
}

.playlist-toggle {
    font-size: 12px;
    color: var(--text-secondary);
    transition: transform 0.3s;
    margin-right: 8px;
}

/* 歌单详情 */
.playlist-detail {
    border-top: 1px solid #eee;
    padding-top: 10px;
    margin-top: 8px;
}

.playlist-song-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.2s;
}

.playlist-song-item:hover {
    background: #f5f5f5;
}

.song-cover {
    width: 36px;
    height: 36px;
    border-radius: 4px;
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f0f0f0;
}

.song-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.song-name {
    flex: 1;
    font-size: 14px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.song-remove {
    background: none;
    border: none;
    color: #999;
    cursor: pointer;
    padding: 4px 8px;
    font-size: 12px;
    opacity: 0;
    transition: opacity 0.2s;
}

.playlist-song-item:hover .song-remove {
    opacity: 1;
}

.song-remove:hover {
    color: var(--error-color);
}

/* 搜索功能样式 */
.search-section {
    margin-top: 15px;
    padding: 15px;
    background: #fafafa;
    border-radius: 8px;
}

.search-input-group {
    display: flex;
    gap: 8px;
}

.search-input-group input {
    flex: 1;
    padding: 10px 12px;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s;
}

.search-input-group input:focus {
    border-color: var(--primary-color);
}

.search-input-group button {
    padding: 10px 20px;
    background: var(--primary-color);
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 14px;
    transition: background 0.2s;
}

.search-input-group button:hover {
    background: var(--primary-hover);
}

.search-results {
    margin-top: 12px;
    max-height: 300px;
    overflow-y: auto;
}

.search-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px;
    background: white;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    margin-bottom: 8px;
    cursor: pointer;
    transition: all 0.2s;
}

.search-item:hover {
    border-color: var(--primary-color);
    box-shadow: 0 2px 8px rgba(0, 161, 214, 0.15);
}

.search-item-cover {
    width: 80px;
    height: 60px;
    object-fit: cover;
    border-radius: 4px;
    background: #eee;
}

.search-item-info {
    flex: 1;
    min-width: 0;
}

.search-item-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.search-item-author {
    font-size: 12px;
    color: var(--text-secondary);
    margin-top: 4px;
}

.search-item-download {
    padding: 6px 12px;
    background: var(--success-color);
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 12px;
    white-space: nowrap;
}

.search-item-download:hover {
    background: #45a019;
}

.search-loading {
    text-align: center;
    padding: 20px;
    color: var(--text-secondary);
}

.search-empty {
    text-align: center;
    padding: 20px;
    color: var(--text-secondary);
    font-size: 14px;
}